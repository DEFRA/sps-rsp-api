
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "APIM Self-Serve API Definition (v3.4 with PRE_BACKEND_URL)",
  "type": "object",
  "additionalProperties": true,

  "required": [
    "API_NAME",
    "API_DISPLAY_NAME",
    "BACKEND_SCOPEID_KEYNAME",
    "FRONTEND_CLIENTID_KEYNAME",
    "TENANT_ID"
  ],

  "properties": {
    "API_NAME": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9]+(-[A-Za-z0-9]+)*$"
    },
    "API_DISPLAY_NAME": { "type": "string", "minLength": 3 },
    "API_DESCRIPTION": { "type": "string" },
    "API_VERSION": {
      "type": "string",
      "pattern": "^v\\d+(\\.\\d+)?$",
      "default": "v1.0"
    },

    "BASE_BACKEND_URL": { "type": "string", "minLength": 1 },

    "BACKEND_SCOPEID_KEYNAME": { "type": "string", "minLength": 1 },
    "FRONTEND_CLIENTID_KEYNAME": { "type": "string", "minLength": 1 },

    "TENANT_ID": { "type": "string", "minLength": 1 },

    "RATE_LIMIT_CALLS": { "type": "integer", "minimum": 0 },
    "RATE_LIMIT_PERIOD": { "type": "integer", "minimum": 0 },

    "DEV_BACKEND_URL": { "type": "string", "minLength": 1 },
    "TST_BACKEND_URL": { "type": "string", "minLength": 1 },
    "PRE_BACKEND_URL": { "type": "string", "minLength": 1 }
  }
}